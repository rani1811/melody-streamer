{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Music App Kubernetes Monitoring",
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage per Pod",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"music-app\"}[5m])) by (pod)",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Memory Usage per Pod",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"music-app\"}) by (pod)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pod Count (music-app)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "count(kube_pod_info{namespace=\"music-app\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pod Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "count by (phase) (kube_pod_status_phase{namespace=\"music-app\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Network Traffic per Pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"music-app\"}[5m])) by (pod)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Pod Restart Count",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"music-app\"}) by (pod)",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 42,
  "title": "Melody Streamer - Kubernetes Monitoring",
  "uid": "melody-streamer-k8s",
  "version": 1
}
